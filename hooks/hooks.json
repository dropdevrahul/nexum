{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/dedup.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Read|Bash|Grep|Glob|Edit|Write|MultiEdit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/scan_guard.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash|Grep|Glob|Read"
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/predup.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Read|Bash|Grep|Glob"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/resume_nudge.py",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/audit_nudge.py",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/session_reset.py",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/precompact.py",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/subagent_usage.py",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/context_watch.py",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}
